# =============================================================================
# metaloops-toolkit configuration file
# Copy this file to local.env and edit the values below.
# All scripts in scripts/ will source this file automatically.
# =============================================================================

# ── Paths ─────────────────────────────────────────────────────────────────────

# Directory containing input .h5 files (for h5_to_bedpe.py)
H5_DIR="h5_files"

# Directory containing input .bedpe files (for bedpe_to_cool.sh)
BEDPE_DIR="bedpe_files"

# Directory where .cool files will be written (for bedpe_to_cool.sh)
COOL_DIR="cool_files"

# Directory where .mcool files will be written (for cool_to_mcool.sh)
MCOOL_DIR="mcool_files"

# Directory where meta-loop results will be written (for run_metaloops.sh)
RESULTS_DIR="results"

# Chromosome sizes file (must match your genome assembly)
CHROM_SIZES="config/dm6.chrom.sizes.txt"


# ── Genome & Hi-C parameters ──────────────────────────────────────────────────

# Genome assembly name (used by cooler --assembly)
ASSEMBLY="dm6"

# Base resolution in base pairs for the .cool file
RESOLUTION=4000

# Additional resolutions for the .mcool file (comma-separated, no spaces)
# Must be multiples of RESOLUTION
MCOOL_RESOLUTIONS="4000,8000,16000,32000"

# Chromosomes to exclude when converting .h5 to BEDPE (for h5_to_bedpe.py)
BLACKLIST_CHR="chrM|chrY"

# Minimum contact count to include when converting .h5 to BEDPE (for h5_to_bedpe.py)
# Contacts with fewer reads than this are discarded. 0 = keep all.
MIN_COUNT=5

# Chromosomes to analyse with meta_loops.R (comma-separated, no spaces)
METALOOPS_CHROMOSOMES="chr2L,chr2R,chr3L,chr3R,chr4,chrX"


# ── Conda environment ─────────────────────────────────────────────────────────

CONDA_ENV="metaloops"


# ── SLURM settings (only relevant when submitting with sbatch) ────────────────

SLURM_PARTITION="irbio01"
SLURM_CPUS=24
SLURM_MEM="32G"
SLURM_TIME="04:00:00"
