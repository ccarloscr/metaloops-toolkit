# Example configuration for metaloops-25.
# Copy this file to config/local.env and edit the values.

# -------------------------
# Project paths
# -------------------------

PROJECT_DIR="/path/to/metaloops-25"

H5_DIR="${PROJECT_DIR}/data/h5"
BEDPE_DIR="${PROJECT_DIR}/data/bedpe"
COOL_DIR="${PROJECT_DIR}/data/cool"
MCOOL_DIR="${PROJECT_DIR}/data/mcool"
RESULTS_DIR="${PROJECT_DIR}/results"
LOG_DIR="${PROJECT_DIR}/logs"

# -------------------------
# Genome settings
# -------------------------

GENOME="dm6"
CHROM_SIZES="${PROJECT_DIR}/config/dm6.chrom.sizes.txt"
CHROMS="chr2L,chr2R,chr3L,chr3R,chrX"

# -------------------------
# Resolution settings
# -------------------------

RESOLUTION=4000
ZOOMIFY_RESOLUTIONS="2000,4000,8000,10000,20000"

# -------------------------
# H5 to BEDPE settings
# -------------------------

MIN_COUNT=1

# -------------------------
# Conda settings
# -------------------------

CONDA_ENV="metaloops"

# If your cluster needs manual conda initialization, edit this.
CONDA_BASE="/path/to/miniconda3"

# -------------------------
# SLURM settings
# -------------------------

SLURM_PARTITION="your_partition"
SLURM_ACCOUNT=""
SLURM_TIME="12:00:00"
SLURM_MEM="32G"
SLURM_CPUS=4
