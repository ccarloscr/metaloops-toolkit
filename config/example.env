# Copy this file to config/local.env and edit it for your system.

# Project paths
PROJECT_DIR="/path/to/metaloops-25"
INPUT_DIR="/path/to/input"
OUTPUT_DIR="/path/to/output"

# Genome settings
GENOME="dm6"
CHROM_SIZES="${PROJECT_DIR}/config/dm6.chrom.sizes.txt"
CHROMS="chr2L,chr2R,chr3L,chr3R,chrX"

# Cooler/metaloops settings
RESOLUTION=4000
ZOOMIFY_RESOLUTIONS="2000,4000,8000,10000,20000"

# Conda
CONDA_ENV="metaloops"
CONDA_BASE="/path/to/miniconda3"

# SLURM resources
SLURM_PARTITION="your_partition"
SLURM_CPUS=4
SLURM_MEM="32G"
SLURM_TIME="12:00:00"
